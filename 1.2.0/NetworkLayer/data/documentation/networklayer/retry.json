{"metadata":{"title":"Retry","role":"article","roleHeading":"Article","modules":[{"name":"NetworkLayer"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/networklayer\/retry"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/network-layer.NetworkLayer\/documentation\/NetworkLayer"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/network-layer.NetworkLayer\/documentation\/NetworkLayer\/Retry"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Learn how to retry failed requests.","type":"text"}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"network-layer"},{"type":"text","text":" is implemented using the "},{"type":"codeVoice","code":"Typhoon"},{"type":"text","text":" framework to handle the retrying of failed requests. You can read more about "},{"type":"codeVoice","code":"Typhoon"},{"type":"text","text":" framework "},{"type":"reference","identifier":"https:\/\/github.com\/space-code\/typhoon\/","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Retrying-Failed-Requests","level":2,"type":"heading","text":"Retrying Failed Requests"},{"inlineContent":[{"type":"text","text":"By default, the "},{"type":"codeVoice","code":"network-layer"},{"type":"text","text":" attempts to resend a failed request five times. If you wish to customize this behavior, you can pass the desired value to an assembly of the "},{"type":"codeVoice","code":"RequestProcessor"},{"type":"text","text":"."}],"type":"paragraph"},{"code":["import NetworkLayer","import NetworkLayerInterfaces","","let requestProcessor = NetworkLayerAssembly.assemble(retryPolicyStrategy: .constant(retry: 10, duration: .seconds(1)))"],"syntax":"swift","type":"codeListing"},{"style":"tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"typhoon","type":"codeVoice"},{"text":" framework provides different strategies for retrying failed request. You can read more ","type":"text"},{"identifier":"https:\/\/github.com\/space-code\/typhoon","isActive":true,"type":"reference"},{"text":".","type":"text"}]}],"name":"Tip","type":"aside"},{"inlineContent":[{"type":"text","text":"This behavior will be applied to all future requests."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In case you desire to customize a particular request, you can pass the desired strategy to that specific request:"}],"type":"paragraph"},{"code":["import NetworkLayerInterfaces","","let request = UserRequest(id: 1)","let user: Response<User> = try await requestProcessor.send(request, strategy: .constant(retry: 10, duration: .seconds(1)))"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"kind":"article","references":{"https://github.com/space-code/typhoon":{"titleInlineContent":[{"text":"here","type":"text"}],"identifier":"https:\/\/github.com\/space-code\/typhoon","type":"link","title":"here","url":"https:\/\/github.com\/space-code\/typhoon"},"doc://network-layer.NetworkLayer/documentation/NetworkLayer":{"type":"topic","url":"\/documentation\/networklayer","kind":"symbol","role":"collection","identifier":"doc:\/\/network-layer.NetworkLayer\/documentation\/NetworkLayer","abstract":[{"type":"text","text":"The library for network communication."}],"title":"NetworkLayer"},"https://github.com/space-code/typhoon/":{"identifier":"https:\/\/github.com\/space-code\/typhoon\/","title":"here","type":"link","url":"https:\/\/github.com\/space-code\/typhoon\/","titleInlineContent":[{"text":"here","type":"text"}]}}}